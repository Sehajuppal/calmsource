<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Exclude Room database files from backup. The database contains
         server URLs, usernames, and other sensitive provider metadata
         that should not be transferred between devices. -->
    <exclude domain="database" path="calmsource_db" />
    <exclude domain="database" path="calmsource_db-wal" />
    <exclude domain="database" path="calmsource_db-shm" />
    <exclude domain="database" path="discovery_engine.db" />
    <exclude domain="database" path="discovery_engine.db-wal" />
    <exclude domain="database" path="discovery_engine.db-shm" />
    <!-- Exclude EncryptedSharedPreferences backing files. While encrypted,
         the master key is device-bound and cannot be recovered on transfer. -->
    <exclude domain="sharedpref" path="iptv_secure_prefs.xml" />
    <exclude domain="sharedpref" path="debrid_secure_prefs.xml" />
</full-backup-content>